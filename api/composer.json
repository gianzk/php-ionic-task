{
    "name": "todoapp/api",
    "description": "REST API for TodoApp with PHP 8",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "vlucas/phpdotenv": "^5.4",
        "bramus/router": "^1.6",
        "firebase/php-jwt": "~6.10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "TodoApp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TodoApp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "echo 'Autoload complete'"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}